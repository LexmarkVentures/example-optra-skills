#!/bin/sh

# These are populated automatically for Optra deployments.
if [ -z "$GST_PLUGIN_PATH" ]; then
  export GST_PLUGIN_PATH=/host/usr/lib/gstreamer-1.0
fi
if [ -z "$MPG123_MODDIR" ]; then
  export MPG123_MODDIR=/host/usr/lib/mpg123
fi
if [ -z "$GST_MPP_VIDEODEC_DEFAULT_ARM_AFBC" ]; then
  export GST_MPP_VIDEODEC_DEFAULT_ARM_AFBC=1
fi

# Paths in /host map to the host file system. Leveraging libs from there
# ensures compatibility and reduces image size.
export LD_LIBRARY_PATH=/host/usr/lib

export PATH="$PATH:/app/bin"
export DISPLAY=:0
